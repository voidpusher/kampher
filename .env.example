# ── App ────────────────────────────────────────────────────────────────
KAMPHER_ENV=dev                      # dev | staging | prod
KAMPHER_LOG_LEVEL=INFO
KAMPHER_API_HOST=0.0.0.0
KAMPHER_API_PORT=8000
KAMPHER_CORS_ORIGINS=["http://localhost:3000"]

# ── PostgreSQL ─────────────────────────────────────────────────────────
KAMPHER_DATABASE_URL=postgresql+asyncpg://kampher:kampher@localhost:5432/kampher
KAMPHER_DATABASE_URL_SYNC=postgresql+psycopg://kampher:kampher@localhost:5432/kampher

# ── Redis / Celery ─────────────────────────────────────────────────────
KAMPHER_REDIS_URL=redis://localhost:6379/0
KAMPHER_REDIS_HEALTH_CHECK=false

# ── Qdrant ─────────────────────────────────────────────────────────────
KAMPHER_QDRANT_URL=http://localhost:6333
KAMPHER_QDRANT_API_KEY=
# No-Docker option: set a directory to run Qdrant embedded (single-process).
# KAMPHER_QDRANT_PATH=./data/qdrant

# ── AI ────────────────────────────────────────────────────────────────
KAMPHER_LLM_PROVIDER=anthropic                 # anthropic | gemini
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
KAMPHER_LLM_MODEL=claude-sonnet-5              # heavy reasoning stages
KAMPHER_LLM_MODEL_FAST=claude-haiku-4-5-20251001  # high-volume classification stages
KAMPHER_EMBEDDING_PROVIDER=fastembed           # fastembed (ONNX, light) | local (torch)
KAMPHER_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
KAMPHER_EMBEDDING_DIM=384
KAMPHER_PIPELINE_VERSION=1

# ── Sources (leave blank to disable a source) ──────────────────────────
# Reddit (script app: https://www.reddit.com/prefs/apps)
KAMPHER_REDDIT_CLIENT_ID=
KAMPHER_REDDIT_CLIENT_SECRET=
KAMPHER_REDDIT_USER_AGENT=kampher/0.1 (opportunity research)
KAMPHER_REDDIT_SUBREDDITS=["SaaS","startups","Entrepreneur","webdev","devops","sysadmin","smallbusiness","marketing","programming"]

# X API v2 bearer token
KAMPHER_X_BEARER_TOKEN=
KAMPHER_X_QUERIES=["\"is there a tool\" lang:en -is:retweet","\"why is there no\" app lang:en -is:retweet"]

# GitHub personal access token (public_repo read)
KAMPHER_GITHUB_TOKEN=
KAMPHER_GITHUB_REPOS=["vercel/next.js","supabase/supabase","langchain-ai/langchain"]

# Hacker News needs no credentials
KAMPHER_HN_ENABLED=true

# Stack Overflow: anonymous API access (300 req/day); optional free key → 10k/day
KAMPHER_STACKOVERFLOW_ENABLED=true
KAMPHER_STACKOVERFLOW_TAGS=["authentication","payments","deployment","web-scraping","saas"]
KAMPHER_STACKOVERFLOW_KEY=

# Lobsters: public JSON feed, no credentials
KAMPHER_LOBSTERS_ENABLED=true

# Dev.to: public Forem API, no credentials
KAMPHER_DEVTO_ENABLED=true
KAMPHER_DEVTO_TAGS=["devops","webdev","productivity","startup","career"]
